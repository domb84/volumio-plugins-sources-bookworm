[Unit]
Description=retrotuner-ui
After=volumio.service

[Service]
User=volumio
Group=volumio
WorkingDirectory=/data/plugins/user_interface/retrotuner-ui/
ExecStart=/data/retrotuner-ui/venv/bin/python3 /data/plugins/user_interface/retrotuner-ui/index.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
