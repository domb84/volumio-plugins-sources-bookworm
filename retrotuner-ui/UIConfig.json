      "id": "buttons",
      "element": "section",
      "label": "Button ADC Pin Configuration",
      "icon": "fa-cogs",
      "description": "Pin configuration to read button presses from an MCP3008 ADC.",
      "onSave": {
        "type": "controller",
        "endpoint":"user_interface/retrotuner-ui",
        "method":"saveOptions"
      },
      "saveButton": {
        "label": "Save",
        "data": [
          "spi",
          "spi_bus",
          "buttons_clk",
          "buttons_miso",
          "buttons_mosi",
          "buttons_cs",
          "buttons_channel1",
          "buttons_channel2",
          "button_poll_rate",
          "button_debounce_rate",
          "button_cooldown_rate"
        ]
      },
